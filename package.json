{
  "name": "skills-marketplace",
  "version": "0.1.0",
  "description": "A local catalog of Codex skills with a TypeScript CLI to discover, install, and validate them.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "skills": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "lint": "tsc --noEmit",
    "validate": "tsx src/cli.ts validate",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
